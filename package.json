{
  "name": "notblox-mono",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "shared",
    "front",
    "back"
  ],
  "scripts": {
    "build:shared": "pnpm --filter @notblox/shared run build",
    "dev:shared": "pnpm --filter @notblox/shared run dev",
    "build:back": "pnpm --filter @notblox/back run build",
    "dev:back": "pnpm --filter @notblox/back run dev",
    "build:front": "pnpm --filter @notblox/front run build",
    "dev:front": "pnpm --filter @notblox/front run dev",
    "build-vercel": "pnpm run build:shared && pnpm run build:front",
    "build": "pnpm run build:shared && pnpm run build:back && pnpm run build:front",
    "dev": "concurrently \"pnpm run dev:shared\" \"pnpm run dev:back\" \"pnpm run dev:front\"",
    "lag:up": "sudo tc qdisc add dev lo root netem delay 100ms",
    "lag:down": "sudo tc qdisc del dev lo root netem"
  },
  "devDependencies": {
    "concurrently": "^10.0.0"
  },
  "pnpm": {
    "overrides": {
      "flatted": "^3.4.2",
      "minimatch@10": "^10.2.3",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@5": "^5.0.3",
      "jiti": "^2.6.1"
    }
  }
}
